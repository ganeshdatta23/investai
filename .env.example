# Copy to .env and fill in. Never commit .env.
# Register an app at https://account.upstox.com/developer/apps to obtain these.
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_REDIRECT_URI=https://127.0.0.1:5000/callback

# Optional — only needed if reasoning.engine = anthropic
ANTHROPIC_API_KEY=

# Optional — for survivorship-free research data (investai ingest-eodhd).
# Subscribe to an EODHD plan that includes DELISTED data (verify on their pricing page),
# then paste your key here.
EODHD_API_KEY=

# Daily summary emails (Gmail SMTP). EMAIL_APP_PASSWORD is a Gmail App Password
# (Google Account -> Security -> App passwords), 16 chars. Spaces are ignored.
EMAIL_FROM=your_sender@gmail.com
EMAIL_APP_PASSWORD=
